## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userbg
*.usertasks

# User-specific files (MonoDevelop/ActiveState ActiveGo)
*.xamarin.user

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Ob]ject/
[Oo]bj/
Generated Files/
TempBuildOutputs/

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/
# Generated user database file
*.sqlite
*.db
*.db-shm
*.db-wal

# Rider
.idea/

# VS Code
.vscode/

# Backup and restore files from NuGet
restore.txt
[Pp]ackages/
[Pp]roject.assets.json
[Pp]roject.lock.json

# Tooling
_ReSharper*/
*.[Re]Sharper.user

# Local History for Visual Studio Code
.history/

# Command line history
.bash_history
.zsh_history

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
